      "title": "Top Protocols",
      "data_source": "protocol_stats",
      "query": {
        "group_by": [
          "protocol"
        ],
        "metrics": [
          {
            "type": "count",
            "field": "*",
            "as": "packets"
          }
        ],
        "sort": [
          {
            "field": "packets",
            "direction": "desc"
          }
        ],
        "limit": 10
      },
      "visualization": {
        "type": "bar",
        "category_field": "protocol",
        "value_field": "packets",
        "show_legend": false,
        "show_labels": true
      },
      "layout": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "description": "Top protocols by packet count",
      "style": {
        "display_mode": "chart"
      }
    },
    {
      "id": "bbbbbbbb-cccc-dddd-eeee-ffffffffffff",
      "title": "DNS Query Table",
      "data_source": "dns_queries",
      "query": {
        "sort": [
          {
            "field": "count",
            "direction": "desc"
          }
        ],
        "limit": 15,
        "columns": [
          "query",
          "count",
          "responses",
          "avg_time_ms"
